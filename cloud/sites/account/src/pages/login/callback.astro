---
import Base from '../../layouts/Base.astro';
const reqUrl = new URL(Astro.request.url);
const token = reqUrl.searchParams.get('t');

let ok = false;
let setCookie: string | null = null;
if (token) {
  // Same-origin call; build an absolute URL from the incoming request
  // so the Worker fetch has a valid origin.
  const exchangeUrl = new URL('/api/v1/auth/exchange', reqUrl.origin);
  const res = await fetch(exchangeUrl.toString(), {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ token }),
  });
  ok = res.ok;
  setCookie = res.headers.get('Set-Cookie');
}

if (ok && setCookie) {
  // Redirect to the account portal root (Astro `base: '/account'`).
  return new Response(null, {
    status: 302,
    headers: { Location: '/account/', 'Set-Cookie': setCookie },
  });
}
---
<Base title="Sign-in failed — carbonbook" lang="en">
  <h1 class="text-2xl font-bold">Sign-in link invalid</h1>
  <p class="mt-2 text-[color:var(--color-ink-500)]">
    The link is expired or has already been used.
  </p>
  <p class="mt-4">
    <a href="/account/login" class="underline text-[color:var(--color-brand-500)]">Request a new link</a>
  </p>
</Base>
