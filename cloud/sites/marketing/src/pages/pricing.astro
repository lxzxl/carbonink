---
import Base from '../layouts/Base.astro';
import PricingFaq from '../components/PricingFaq.astro';
import PricingPlans from '../components/PricingPlans.astro';
---
<Base title="碳墨 — 定价" lang="zh-CN">
  <section class="py-20 px-5">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-semibold tracking-tight mb-3">简单透明的定价</h1>
        <p class="text-muted-foreground leading-relaxed">14 天免费试用，无需信用卡，到期自动降级不扣费。</p>
      </div>

      <PricingPlans lang="zh-CN" />
      <PricingFaq lang="zh-CN" />
    </div>
  </section>
</Base>
