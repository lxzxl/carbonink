---
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import '../styles/global.css';

const { title, lang = 'zh-CN', description } = Astro.props as {
  title: string;
  lang?: 'zh-CN' | 'en';
  description?: string;
};

const defaultDesc = lang === 'zh-CN'
  ? '碳墨 — 完全离线运行的桌面端碳核算工具。AI 解析单据，一键导出 ISO 14064-1 报告。'
  : 'CarbonInk — local-first GHG accounting for factories. AI extracts emission data from bills. One-click ISO 14064-1 report.';

// Canonical URL + OG image URL — we use carbonink.xyz as the
// public origin. The OG image reuses the same `/screenshots/dashboard.png`
// we ship for the hero (1400×900 fits the 1.91:1 OG/Twitter card
// ratio cleanly when displayed in Slack / WeChat / Twitter previews).
// `noindex` would be wrong here — marketing IS the indexable surface.
const canonicalUrl = new URL(Astro.url.pathname, 'https://carbonink.xyz').toString();
const ogImage = 'https://carbonink.xyz/screenshots/dashboard.png';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description ?? defaultDesc} />
    <link rel="canonical" href={canonicalUrl} />

    {/* Favicon — inline SVG re-uses the LogoMark vector, so the tab
        icon, bookmark icon, and in-page brand all read as the same
        identity. PNG fallback not shipped today; modern browsers
        (Chrome 80+, Safari 12+, Firefox 41+) all honor SVG favicons,
        and the cloud site doesn't need to support IE. */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Open Graph + Twitter Card metadata.
        Slack / WeChat / Twitter / LinkedIn / Telegram all read OG
        first; the screenshot embed makes the link preview show the
        real dashboard, not a generic logo card. og:type=website
        because the marketing pages are not articles. */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="CarbonInk" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description ?? defaultDesc} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1400" />
    <meta property="og:image:height" content="900" />
    <meta property="og:locale" content={lang === 'zh-CN' ? 'zh_CN' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description ?? defaultDesc} />
    <meta name="twitter:image" content={ogImage} />

    {/* Self-host Inter Variable + JetBrains Mono via Google Fonts CDN.
        `display=swap` lets text render in the fallback while the
        variable font streams in, avoiding the 1-2s FOIT users see on
        slow connections. Pinned to weight 400/500/600 (we don't use
        heavier weights anywhere in the design) to keep the request
        small. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@400;500;600&display=swap" />
  </head>
  <body class="bg-background text-foreground font-[family-name:var(--font-body)] min-h-screen flex flex-col">
    <Nav lang={lang} />
    {/* pt-14 clears the fixed Nav (h-14). `flex-1` keeps the footer at
        the bottom of short pages without the awkward "footer floating
        in the middle" effect on near-empty placeholder pages. */}
    <main class="flex-1 pt-14"><slot /></main>
    <Footer lang={lang} />
  </body>
</html>
