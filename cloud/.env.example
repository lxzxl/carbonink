# Cloudflare deploy + worker secrets — copy to cloud/.env.local and fill in.
# .env.local is gitignored.
#
# Usage:
#   - source cloud/.env.local in your shell before running deploy scripts, OR
#   - the scripts will source it automatically if present.

# ============================================================================
# Cloudflare API auth (used by wrangler)
# ============================================================================
#
# Create at:
#   https://dash.cloudflare.com/profile/api-tokens → Create Token
#
# Template: "Edit Cloudflare Workers" gives 90% of what you need.
# Or use Custom Token with these scopes:
#
#   Account permissions:
#     - Workers Scripts: Edit
#     - Workers KV Storage: Edit
#     - Workers R2 Storage: Edit
#     - D1: Edit
#     - Account Settings: Read
#   Zone permissions (for carbonink.xyz):
#     - Workers Routes: Edit
#     - Zone: Read
#   Account Resources: Include — Specific account: <your account>
#   Zone Resources: Include — Specific zone: carbonink.xyz
#
# Test token works:
#   CLOUDFLARE_API_TOKEN=... pnpm exec wrangler whoami
#
CLOUDFLARE_API_TOKEN=

# Optional: account ID (auto-detected from token in most cases, but some
# commands prefer explicit). Find in dashboard URL: dash.cloudflare.com/<id>/...
CLOUDFLARE_ACCOUNT_ID=

# ============================================================================
# Worker secrets (pushed by cloud/scripts/push-secrets.sh)
# ============================================================================
# These get sent to Cloudflare via `wrangler secret bulk` — never logged,
# never committed. Don't paste into any other file.

# Ed25519 64-byte hex (32-byte seed + 32-byte pubkey concatenated).
# Generate via: cd cloud/worker && pnpm exec tsx scripts/gen-keypair.ts
LICENSE_PRIVATE_KEY_HEX=

# Separate Ed25519 key for account-portal session JWTs (NOT the same as above).
SESSION_PRIVATE_KEY_HEX=

# Stripe — get from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=

# Stripe webhook signing secret — created when you add the webhook endpoint
# in Stripe dashboard (https://carbonink.xyz/api/v1/stripe-webhook).
STRIPE_WEBHOOK_SECRET=

# Email (activation + magic-link) is delivered via Cloudflare's
# native Email Sending binding — no API key, no third-party SaaS.
# Onboard the domain once via:
#   cd cloud/worker && pnpm exec wrangler email sending enable carbonink.xyz
