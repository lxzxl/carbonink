---
export const prerender = true;

import Base from '../layouts/Base.astro';
import DownloadButtons from '../components/DownloadButtons.astro';
import LogoMark from '../components/LogoMark.astro';

const version = 'v0.4.1';
---
<Base title="Download — CarbonInk" lang="en">
  <section class="py-28 px-5">
    <div class="max-w-lg mx-auto text-center">
      <div class="inline-flex justify-center">
        <LogoMark size={44} />
      </div>
      <h1 class="text-3xl font-semibold tracking-tight mt-6 mb-2">Download CarbonInk</h1>
      <p class="text-muted-foreground text-sm mb-10" style="font-family: var(--font-mono);">
        Version {version} — auto-update included
      </p>

      <DownloadButtons lang="en" />
    </div>
  </section>
</Base>
