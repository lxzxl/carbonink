---
import Base from '../../../layouts/Base.astro';
import LogoMark from '../../../components/LogoMark.astro';

/**
 * /account/login — magic-link email form. Public (no session
 * required); the middleware whitelists `/account/login*` paths.
 *
 * Renders `bare` (Base.astro doesn't ship Nav/Footer here) since
 * the login surface should be a focused, modal-feel card. The
 * middleware does NOT gate this path.
 *
 * Lang from URL prefix: `/account/login` = zh, `/en/account/login`
 * = en. The two routes share the same form copy keyed off
 * `Astro.url.pathname`.
 */

const url = new URL(Astro.request.url);
const lang: 'zh-CN' | 'en' = url.pathname.startsWith('/en/') ? 'en' : 'zh-CN';
const isZh = lang === 'zh-CN';

const tx = isZh
  ? {
      title: '登录 — 碳墨账户',
      brand: '碳墨',
      heading: '登录账户',
      body: '我们会给你发一封含有登录链接的邮件，无需密码。',
      emailLabel: '邮箱',
      submit: '发送登录链接',
      sentTitle: '已发送',
      errorTip: '未能发送登录链接，请重试。',
      networkTip: '网络错误，请重试。',
    }
  : {
      title: 'Sign in — CarbonInk account',
      brand: 'CarbonInk',
      heading: 'Sign in to your account',
      body: "We'll send you a magic link. No password needed.",
      emailLabel: 'Email',
      submit: 'Send sign-in link',
      sentTitle: 'Link sent',
      errorTip: 'Could not send the sign-in link. Please try again.',
      networkTip: 'Network error. Please try again.',
    };
---
<Base title={tx.title} lang={lang}>
  <div class="min-h-screen flex items-center justify-center px-5 py-12">
    <div class="max-w-sm w-full">
      <div class="flex items-center gap-2 justify-center mb-8">
        <LogoMark size={28} />
        <span class="font-semibold text-[15px]">{tx.brand}</span>
      </div>

      <div class="border border-border rounded-xl bg-background p-8 shadow-sm">
        <div id="form-view">
          <h2 class="font-semibold text-lg mb-1">{tx.heading}</h2>
          <p class="text-sm text-muted-foreground mb-6 leading-relaxed">{tx.body}</p>
          <form id="login-form" class="flex flex-col gap-3">
            <label class="text-sm">
              <span class="block mb-1.5">{tx.emailLabel}</span>
              <input
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder="your@company.com"
                class="w-full border border-border rounded px-3 py-2.5 text-sm bg-input-background focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary placeholder:text-muted-foreground"
              />
            </label>
            <button
              type="submit"
              class="bg-primary text-primary-foreground py-2.5 rounded text-sm font-medium hover:bg-moss-600 transition-colors"
            >
              {tx.submit}
            </button>
            <p
              id="error"
              class="hidden text-sm text-destructive"
              data-error-tip={tx.errorTip}
              data-network-tip={tx.networkTip}
            ></p>
          </form>
        </div>

        <div id="sent-view" class="hidden text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-moss-50 border border-moss-100 mb-3">
            <svg class="w-6 h-6 text-moss-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,13 2,6" />
            </svg>
          </div>
          <h2 class="font-semibold text-lg mb-2">{tx.sentTitle}</h2>
          <p
            id="sent-body"
            class="text-sm text-muted-foreground leading-relaxed"
            data-zh="登录链接已发到 {email}，请在 15 分钟内点击。"
            data-en="A sign-in link was sent to {email} — expires in 15 minutes."
            data-lang={lang}
          ></p>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    document.getElementById('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const error = document.getElementById('error');
      const formView = document.getElementById('form-view');
      const sentView = document.getElementById('sent-view');
      const sentBody = document.getElementById('sent-body');
      const data = new FormData(form);
      const email = String(data.get('email') ?? '');
      const errTip = error.getAttribute('data-error-tip') || '';
      const netTip = error.getAttribute('data-network-tip') || '';
      error.classList.add('hidden');

      try {
        const res = await fetch('/api/v1/auth/magic-link', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        if (res.ok) {
          formView.classList.add('hidden');
          sentView.classList.remove('hidden');
          const tmpl = sentBody.getAttribute(sentBody.getAttribute('data-lang') === 'zh-CN' ? 'data-zh' : 'data-en') || '';
          sentBody.textContent = tmpl.replace('{email}', email);
        } else {
          error.textContent = errTip;
          error.classList.remove('hidden');
        }
      } catch {
        error.textContent = netTip;
        error.classList.remove('hidden');
      }
    });
  </script>
</Base>
