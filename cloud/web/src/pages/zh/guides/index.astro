---
export const prerender = true;

import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';

const guides = (await getCollection('guides', ({ id }) => id.startsWith('zh/'))).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---
<Base
  title="指南 — 碳核算 / 碳盘查 / ISO 14064-1 实操 | 碳墨"
  description="面向实操的碳核算指南：ISO 14064-1 温室气体清单编制七步、ISO 14064-1 与 GHG Protocol 的区别、碳盘查和碳核查的区别等，持续更新。"
  lang="zh-CN"
>
  <section class="py-16 px-5">
    <div class="max-w-3xl mx-auto">
      <p class="text-xs font-medium text-primary uppercase tracking-widest mb-3">指南</p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight mb-3">把碳核算讲清楚</h1>
      <p class="text-muted-foreground leading-relaxed mb-12 max-w-2xl">
        中立、贴标准的碳盘查实操指南 —— 写给要把数字送过审核员那一关的顾问和企业可持续团队。
      </p>
      <ul class="divide-y divide-border border border-border rounded-md">
        {guides.map((g) => (
          <li>
            <a href={`/zh/guides/${g.id.slice(3)}/`} class="block px-5 py-5 hover:bg-muted/30 transition-colors">
              <p class="font-medium text-[15px] mb-1">{g.data.title}</p>
              <p class="text-sm text-muted-foreground">{g.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>
