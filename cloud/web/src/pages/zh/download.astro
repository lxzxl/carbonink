---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import DownloadButtons from '../../components/DownloadButtons.astro';
import LogoMark from '../../components/LogoMark.astro';
// 版本号构建时读 desktop/package.json，禁止写死——这行曾经连着三个版本
// 停在 "v0.4.1"。发布流程先在 main 上 bump 版本再打 tag，站点每次 main
// push 自动重建，页面版本因此与发布同步。下载按钮与此标签无关：它们在
// 请求时实时解析 GitHub 最新 release 资产（lib/latest-download.ts）。
import desktopPkg from '../../../../../desktop/package.json';

const version = `v${desktopPkg.version}`;
---
<Base
  title="下载碳墨 — macOS / Windows 免费碳核算软件"
  description="免费下载碳墨桌面端（macOS / Windows）。开源碳核算 / 碳盘查软件，完全离线运行，无需注册账号。"
  lang="zh-CN"
>
  <section class="py-28 px-5">
    <div class="max-w-lg mx-auto text-center">
      <div class="inline-flex justify-center">
        <LogoMark size={44} />
      </div>
      <h1 class="text-3xl font-semibold tracking-tight mt-6 mb-2">下载碳墨</h1>
      <p class="text-muted-foreground text-sm mb-10" style="font-family: var(--font-mono);">
        当前版本 {version}（Windows 自动更新，macOS 新版提示）
      </p>

      <DownloadButtons lang="zh-CN" />
    </div>
  </section>
</Base>
