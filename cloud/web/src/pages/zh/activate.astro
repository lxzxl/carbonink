---
/**
 * /en/activate — English-locale mirror of /activate. Same SSR flow:
 * resolves Stripe session → license key → renders LicenseKeyCard.
 * The lang detection in activate.astro reads the path prefix, so a
 * single shared component tree handles both URLs.
 *
 * We keep two route files (rather than a [...path] catch-all)
 * because Astro's i18n integration emits separate routes for each
 * locale and the OG metadata + canonical URL in Base.astro reads
 * from the path. Two thin files is cheaper than rewiring those
 * subsystems for a single-locale shortcut.
 */
import LicenseKeyCard from '../../components/LicenseKeyCard.astro';
import LogoMark from '../../components/LogoMark.astro';
import Base from '../../layouts/Base.astro';
import { getApiBinding, getEnv } from '../../lib/api-fetch.ts';
import { lookupLicenseForSession } from '../../lib/stripe-lookup.ts';

const url = new URL(Astro.request.url);
const sessionId = url.searchParams.get('session_id');
const directKey = url.searchParams.get('key');
const lang = 'zh-CN' as const;

let licenseKey: string | null = null;
let lookupError: string | null = null;
if (directKey) {
  licenseKey = directKey;
} else if (sessionId) {
  const { STRIPE_SECRET_KEY } = getEnv<{ STRIPE_SECRET_KEY: string }>();
  const result = await lookupLicenseForSession({
    sessionId,
    stripeSecretKey: STRIPE_SECRET_KEY,
    api: getApiBinding(),
  });
  if (result) licenseKey = result.licenseKey;
  else
    lookupError = 'We could not locate your key — please check your inbox for the activation email, or contact support.';
}

const tx = {
  title: 'Activate CarbonInk',
  brand: 'CarbonInk',
  emptyTitle: 'Check your inbox',
  emptyBody:
    "An activation link has been sent to the email used at checkout. If it hasn't arrived in 5 minutes, check the spam folder.",
  errorTitle: 'License not found',
  contactPre: 'Need help?',
  contactLink: 'Contact support',
};

const supportHref = 'mailto:support@carbonink.xyz';
---
<Base title={tx.title} lang={lang}>
  {licenseKey ? (
    <LicenseKeyCard licenseKey={licenseKey} lang={lang} />
  ) : (
    <div class="min-h-screen flex flex-col items-center justify-center px-5 py-12">
      <div class="flex items-center gap-2 mb-10">
        <LogoMark size={24} />
        <span class="font-semibold text-sm">{tx.brand}</span>
      </div>

      <div class="max-w-md w-full border border-border rounded-xl bg-background shadow-sm p-8 text-center">
        {lookupError ? (
          <>
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-amber-50 border border-amber-200 mb-3">
              <svg class="w-6 h-6 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                <line x1="12" y1="9" x2="12" y2="13" />
                <line x1="12" y1="17" x2="12.01" y2="17" />
              </svg>
            </div>
            <h2 class="font-semibold text-lg mb-2">{tx.errorTitle}</h2>
            <p class="text-sm text-muted-foreground leading-relaxed">{lookupError}</p>
          </>
        ) : (
          <>
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-moss-50 border border-moss-100 mb-3">
              <svg class="w-6 h-6 text-moss-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
            </div>
            <h2 class="font-semibold text-lg mb-2">{tx.emptyTitle}</h2>
            <p class="text-sm text-muted-foreground leading-relaxed">{tx.emptyBody}</p>
          </>
        )}
      </div>

      <p class="text-xs text-muted-foreground mt-6">
        {tx.contactPre} <a href={supportHref} class="text-primary hover:underline">{tx.contactLink}</a>
      </p>
    </div>
  )}
</Base>
