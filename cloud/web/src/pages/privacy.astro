---
export const prerender = true;

import Base from '../layouts/Base.astro';
---
<Base title="CarbonInk — Privacy" lang="en">
  <section class="py-20 px-5">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight mb-2">Privacy Policy</h1>
      <p class="text-sm text-muted-foreground mb-10" style="font-family: var(--font-mono);">
        Effective 2026-05-25
      </p>

      <div class="space-y-8 text-[15px] leading-relaxed text-foreground">
        <section>
          <h2 class="text-xl font-semibold mb-3">We don't collect your inventory data</h2>
          <p class="text-muted-foreground">
            CarbonInk is a local-first desktop application. All inventory data — activity data, emission factors,
            report contents, questionnaire answers, AI conversations — lives only in the SQLite database on your
            device. The cloud never receives this content. No copies, no backups.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold mb-3">What the cloud does know</h2>
          <p class="text-muted-foreground mb-3">To issue and verify licenses, the CarbonInk cloud records:</p>
          <ul class="space-y-2 text-muted-foreground pl-5 list-disc">
            <li>License key (the identifier we issue after you purchase)</li>
            <li>Activated device ID (an anonymous device identifier; no device name, username, or network info)</li>
            <li>Account email (for billing receipts and support correspondence)</li>
            <li>Stripe subscription status (maintained by Stripe; we read-only)</li>
          </ul>
        </section>

        <section>
          <h2 class="text-xl font-semibold mb-3">Third parties</h2>
          <p class="text-muted-foreground">
            Payments are processed by Stripe; we never touch your card information. This site uses no Google
            Analytics, no Mixpanel, no third-party analytics of any kind.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold mb-3">Data export and deletion</h2>
          <p class="text-muted-foreground">
            "My Account" lets you export your account metadata (license, devices, invoices). Clicking
            "Delete account" permanently removes those records and cancels any active subscription. Your local
            database stays under your control — to clear it, delete the app's data directory.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold mb-3">Contact</h2>
          <p class="text-muted-foreground">
            Privacy questions: <a href="mailto:privacy@carbonink.xyz" class="text-primary hover:underline">privacy@carbonink.xyz</a>
          </p>
        </section>
      </div>
    </div>
  </section>
</Base>
