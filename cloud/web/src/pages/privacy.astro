---
export const prerender = true;

import Base from '../layouts/Base.astro';
---
<Base
  title="CarbonInk — Privacy"
  description="CarbonInk is local-first: all inventory data stays in a SQLite database on your device. No accounts, no tracking — cookieless aggregate visit counts only. The full privacy policy."
  lang="en"
>
  <section class="py-20 px-5">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight mb-2">Privacy Policy</h1>
      <p class="text-sm text-muted-foreground mb-10" style="font-family: var(--font-mono);">
        Effective 2026-07-03
      </p>

      <div class="space-y-8 text-[15px] leading-relaxed text-foreground">
        <section>
          <h2 class="text-xl font-semibold mb-3">We don't collect your inventory data</h2>
          <p class="text-muted-foreground">
            CarbonInk is a local-first desktop application. All inventory data — activity data, emission factors,
            report contents, questionnaire answers, AI conversations — lives only in the SQLite database on your
            device. The cloud never receives this content. No copies, no backups.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold mb-3">What the cloud knows</h2>
          <p class="text-muted-foreground">
            Essentially nothing. CarbonInk is free and open-source — there's no account, no activation,
            and no license server. You download the app and run it; the only cloud is this marketing site
            plus the GitHub release you download from.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold mb-3">Third parties</h2>
          <p class="text-muted-foreground">
            No payments, no sign-in, no card details. This website uses Cloudflare Web Analytics for
            aggregate visit counts — it sets no cookies, does no cross-site tracking or fingerprinting,
            and records nothing that identifies you as a person. There is no Google Analytics, no
            Mixpanel, no ad tech. The desktop app itself sends no analytics at all.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold mb-3">Your data</h2>
          <p class="text-muted-foreground">
            Everything you enter lives in a local database on your own machine. It is never uploaded. To
            clear it, delete the app's data directory.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold mb-3">Contact</h2>
          <p class="text-muted-foreground">
            Privacy questions: <a href="mailto:privacy@carbonink.xyz" class="text-primary hover:underline">privacy@carbonink.xyz</a>
          </p>
        </section>
      </div>
    </div>
  </section>
</Base>
