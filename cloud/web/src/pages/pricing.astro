---
export const prerender = true;

import Base from '../layouts/Base.astro';
import PricingFaq from '../components/PricingFaq.astro';
import PricingPlans from '../components/PricingPlans.astro';
---
<Base title="CarbonInk — Pricing" lang="en">
  <section class="py-20 px-5">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-semibold tracking-tight mb-3">Simple, transparent pricing</h1>
        <p class="text-muted-foreground leading-relaxed">14-day free trial. No credit card required. Auto-downgrade at expiry, never charged.</p>
      </div>

      <PricingPlans lang="en" />
      <PricingFaq lang="en" />
    </div>
  </section>
</Base>
