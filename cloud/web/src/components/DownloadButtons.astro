---
/**
 * DownloadButtons — paired mac/win download tiles. Used on /download
 * and reused on the activate portal (where users land mid-install
 * and may need to grab the app first).
 *
 * Apple + Windows SVGs match the Figma source. We don't include
 * Linux today — the build matrix is mac arm64/x64 + win x64, mirror-
 * shipped from the GitHub release page. Once Linux ships we'll add a
 * third tile (and probably switch to a 3-col grid above sm).
 *
 * Version + signing copy is fixed inline. When v0.5 ships we'll move
 * this into env config; today the marketing build is fast enough to
 * rebuild per release.
 */

const { lang } = Astro.props as { lang: 'zh-CN' | 'en' };
const isZh = lang === 'zh-CN';

const tx = isZh
  ? {
      mac: '下载 macOS 版（.dmg）',
      macNote: 'Apple Silicon · macOS 12+',
      macIntel: '使用 Intel 芯片的 Mac？下载 Intel 版',
      win: '下载 Windows 版（.exe）',
      winNote: 'Windows 10/11 x64',
      signing: '应用未做代码签名（开源免费）。首次打开：macOS 请右键点按图标 →「打开」；Windows 在 SmartScreen 提示时选「更多信息 → 仍要运行」。',
    }
  : {
      mac: 'Download for macOS (.dmg)',
      macNote: 'Apple Silicon · macOS 12+',
      macIntel: 'On an Intel Mac? Get the Intel build',
      win: 'Download for Windows (.exe)',
      winNote: 'Windows 10/11 x64',
      signing: "The app isn't code-signed (it's free & open-source). First launch: on macOS, right-click the app → Open; on Windows, choose \"More info → Run anyway\" at the SmartScreen prompt.",
    };

// Worker redirect endpoints (cloud/web/src/pages/download/*.ts) resolve
// the latest GitHub Release asset at request time and 302 to it, so the
// version is never hard-coded here. `/download/mac` defaults to Apple
// Silicon; the Intel link passes `?arch=x64`.
const macHref = '/download/mac';
const winHref = '/download/win';
const macIntelHref = '/download/mac?arch=x64';
---
<div class="flex flex-col gap-3 mb-10">
  <a
    href={macHref}
    class="flex items-center gap-3 border border-border rounded-lg px-5 py-4 hover:bg-muted/50 transition-colors text-left group"
  >
    <div class="w-9 h-9 rounded bg-muted flex items-center justify-center flex-shrink-0">
      <svg viewBox="0 0 24 24" class="w-5 h-5 text-foreground" fill="currentColor" aria-hidden="true">
        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
      </svg>
    </div>
    <div class="flex-1">
      <p class="font-medium text-sm">{tx.mac}</p>
      <p class="text-xs text-muted-foreground mt-0.5" style="font-family: var(--font-mono);">{tx.macNote}</p>
    </div>
    <svg class="w-4 h-4 text-muted-foreground group-hover:text-foreground transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
      <polyline points="7 10 12 15 17 10" />
      <line x1="12" y1="15" x2="12" y2="3" />
    </svg>
  </a>

  <a href={macIntelHref} class="text-xs text-muted-foreground hover:text-foreground transition-colors self-start -mt-1.5 ml-1">
    {tx.macIntel}
  </a>

  <a
    href={winHref}
    class="flex items-center gap-3 border border-border rounded-lg px-5 py-4 hover:bg-muted/50 transition-colors text-left group"
  >
    <div class="w-9 h-9 rounded bg-muted flex items-center justify-center flex-shrink-0">
      <svg viewBox="0 0 24 24" class="w-5 h-5 text-foreground" fill="currentColor" aria-hidden="true">
        <path d="M3 5.557L10.267 4.6l.004 7.343-7.26.043L3 5.557zm7.265 7.158l.006 7.347L3.002 19.1l-.001-6.428 7.264.043zm.898-8.222L21 3v8.895l-9.837.077V4.493zm9.839 8.386l-.002 8.893L11.163 20.6l-.012-7.706 9.851.001z" />
      </svg>
    </div>
    <div class="flex-1">
      <p class="font-medium text-sm">{tx.win}</p>
      <p class="text-xs text-muted-foreground mt-0.5" style="font-family: var(--font-mono);">{tx.winNote}</p>
    </div>
    <svg class="w-4 h-4 text-muted-foreground group-hover:text-foreground transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
      <polyline points="7 10 12 15 17 10" />
      <line x1="12" y1="15" x2="12" y2="3" />
    </svg>
  </a>
</div>

<p class="text-xs text-muted-foreground leading-relaxed border border-border rounded-lg px-4 py-3 bg-muted/40">
  {tx.signing}
</p>
