---
/**
 * PricingFaq — accordion of 6 frequently asked questions about the
 * pricing model. Vanilla JS toggle on each <details>; no external
 * dependency.
 *
 * Using native `<details>` element rather than a JS-driven open state
 * keeps the FAQ functional even if JavaScript is disabled, satisfies
 * screen readers without extra ARIA wiring, and inherits the
 * browser's "open one by default" / "remember scroll position"
 * behavior. The chevron rotates via the `open` attribute, no JS
 * needed.
 */

const { lang } = Astro.props as { lang: 'zh-CN' | 'en' };
const isZh = lang === 'zh-CN';

const tx = isZh
  ? {
      title: '常见问题',
      faqs: [
        { q: '为什么完全离线？', a: '数据安全。碳核算数据属于企业核心资产，涉及能耗、排放及生产工艺，不应上传到第三方云服务。碳墨从架构上保证数据不离开你的设备。' },
        { q: '我的数据存在哪里？', a: '只在你的电脑本地。云端只知道你买了许可证，以及哪台电脑激活了它。我们不知道你算了什么、填了什么、问了什么。' },
        { q: '如何退款？', a: '购买后 30 天内无理由退款，无需说明原因，联系支持即可。' },
        { q: '一个许可证可以用几台电脑？', a: '基础版授权 1 台设备。如需增加设备席位，请联系支持，我们会提供定制方案。' },
        { q: '软件更新怎么收费？', a: '订阅期内所有更新免费，含新功能和 EF 库更新。订阅到期后，已安装版本可继续使用，但不再接收新版本。' },
        { q: '试用结束后会自动扣费吗？', a: '不会。试用期到期后自动降级为只读模式，不绑定任何支付方式，不会自动收费。' },
      ],
    }
  : {
      title: 'Frequently asked questions',
      faqs: [
        { q: 'Why local-only?', a: 'Security. Carbon accounting data is a core enterprise asset — it covers energy consumption, emissions, and production processes. CarbonInk is architected so your data never leaves your device.' },
        { q: 'Where does my data go?', a: "Only your local machine. The cloud knows you bought a license and which computer activated it. We don't know what you calculated, filled, or asked the AI." },
        { q: 'Refund policy?', a: '30-day no-questions-asked refund from date of purchase. Contact support — no reason needed.' },
        { q: 'Multi-device?', a: "The Base plan includes 1 activated device. For additional seats, contact support and we'll provide a custom arrangement." },
        { q: 'Update policy?', a: "All updates are free during your subscription, including new features and EF library refreshes. After expiry, your installed version keeps working but won't receive updates." },
        { q: 'Auto-charge after trial?', a: 'No. Trial expires to read-only mode automatically. No payment method is required during trial, so nothing can be charged.' },
      ],
    };
---
<div class="max-w-2xl mx-auto">
  <h2 class="text-xl font-semibold mb-6">{tx.title}</h2>
  <div class="border border-border rounded-lg overflow-hidden divide-y divide-border">
    {tx.faqs.map((faq) => (
      <details class="group">
        <summary class="flex items-center justify-between px-5 py-4 text-left text-sm font-medium hover:bg-muted/40 transition-colors gap-4 cursor-pointer list-none">
          <span>{faq.q}</span>
          <svg
            class="w-4 h-4 text-muted-foreground flex-shrink-0 transition-transform group-open:rotate-180"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </summary>
        <div class="px-5 pb-4">
          <p class="text-sm text-muted-foreground leading-relaxed">{faq.a}</p>
        </div>
      </details>
    ))}
  </div>
</div>

<style>
  /* Hide the default disclosure triangle that Safari/Firefox add to
   * <summary>. We use a custom chevron SVG that rotates via
   * `group-open` instead. `list-style: none` covers Firefox; the
   * webkit pseudo handles Safari. */
  summary { list-style: none; }
  summary::-webkit-details-marker { display: none; }
</style>
