---
/**
 * PricingTeaser — moss-50 banded section that bridges the marketing
 * page to /pricing without dumping the full price grid here. One
 * sentence of policy ("trial → auto-downgrade") and a "view full
 * pricing" link.
 */

const { lang } = Astro.props as { lang: 'zh-CN' | 'en' };
const isZh = lang === 'zh-CN';

// Pre-paid early-access copy: lead with the 14-day trial (still
// fully working — desktop app calls /v1/trial-signup on install),
// soft-mention the upcoming Base plan ("邀请制"). Avoid "年度订阅"
// up-front when no purchase flow exists yet.
const tx = isZh
  ? {
      copy: '14 天免费试用，无需信用卡。基础版当前邀请制，欢迎在定价页申请。',
      link: '了解早期试用',
    }
  : {
      copy: '14-day free trial, no credit card required. Base plan is currently invite-only — request early access on the pricing page.',
      link: 'Learn about early access',
    };

const prefix = isZh ? '' : '/en';
---
<section class="py-16 px-5 border-y border-border bg-moss-50">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <p class="text-[15px] text-foreground max-w-md leading-relaxed">{tx.copy}</p>
    <a
      href={`${prefix}/pricing/`}
      class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:text-moss-700 transition-colors flex-shrink-0"
    >
      {tx.link}
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </a>
  </div>
</section>
