---
/**
 * PrivacyCallout — a quoted blockquote about the privacy
 * architecture. One short, declarative statement; not a paragraph.
 * The left border in `border-primary` flags it as opinion / value
 * proposition rather than feature copy.
 */

const { lang } = Astro.props as { lang: 'zh-CN' | 'en' };
const isZh = lang === 'zh-CN';

const tx = isZh
  ? {
      label: '数据隐私',
      quote: '碳墨没有账户、没有许可证、不向任何地方上报。你算了什么、填了什么、问 AI 什么——它都无从知道，因为根本没有服务器可上传。',
    }
  : {
      label: 'Privacy by architecture',
      quote: "CarbonInk has no account, no license, nothing that phones home. What you calculated, filed, or asked the AI — it can't know, because there's no server to send it to.",
    };
---
<section class="py-20 px-5">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-2xl">
      <p class="text-xs font-medium text-primary uppercase tracking-widest mb-4">{tx.label}</p>
      <blockquote class="text-xl font-medium leading-relaxed text-foreground border-l-2 border-primary pl-6">
        {tx.quote}
      </blockquote>
    </div>
  </div>
</section>
