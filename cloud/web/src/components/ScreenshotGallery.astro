---
/**
 * ScreenshotGallery — 4-screenshot showcase between Differentiators
 * and Privacy. Not in the Figma source (Figma showed a single hero
 * mock and stopped); added per user request to display real product
 * screenshots in the marketing page.
 *
 * Layout: 2-col grid on md+ with each cell showing one feature
 * (documents → AI extraction; questionnaires → fill flow; sources →
 * EF catalog; reports → ISO 14064-1). Caption sits BELOW the image
 * so the visual stays uncluttered.
 *
 * Each image: real e2e screenshot at 1400 × 900 → loaded lazily
 * (below the fold) with explicit aspect-ratio to prevent CLS.
 */

const { lang } = Astro.props as { lang: 'zh-CN' | 'en' };
const isZh = lang === 'zh-CN';

// Screenshot paths are locale-aware. zh shots live at /screenshots/*;
// en shots at /screenshots/en/* (mirrored layout). See
// cloud/web/public/screenshots/en/README.md for how to regenerate EN
// shots from the desktop app's e2e tour.
const shotDir = isZh ? '/screenshots' : '/screenshots/en';

const tx = isZh
  ? {
      label: '产品截图',
      title: '看碳墨在干什么',
      sub: '所有截图来自真实的桌面应用，不是渲染图。',
      shots: [
        {
          src: `${shotDir}/documents.png`,
          title: 'AI 识别单据',
          body: '电费单、燃料发票、运输单据上传即解析。AI 抽数据，你只确认。',
        },
        {
          src: `${shotDir}/questionnaires.png`,
          title: '问卷自动填报',
          body: '一份核算数据，自动回填客户的 CDP / TCFD 问卷。',
        },
        {
          src: `${shotDir}/sources.png`,
          title: '排放源 + 排放因子库',
          body: 'IPCC / ECOINVENT 排放因子内置；可自建私有 EF 库。',
        },
        {
          src: `${shotDir}/reports.png`,
          title: '盘查 + 披露报告',
          body: 'ISO 14064-1 盘查报告与 TCFD 四支柱披露一键导出；附完整公式、引用与版本号。',
        },
      ],
    }
  : {
      label: 'Product screenshots',
      title: 'See it in action',
      sub: 'All screenshots are from the real desktop app, not renders.',
      shots: [
        {
          src: `${shotDir}/documents.png`,
          title: 'AI bill extraction',
          body: 'Upload electricity bills, fuel invoices, freight records. AI extracts; you confirm.',
        },
        {
          src: `${shotDir}/questionnaires.png`,
          title: 'Fill customer questionnaires',
          body: 'Inventory data auto-populates CDP / TCFD questionnaires for your customers.',
        },
        {
          src: `${shotDir}/sources.png`,
          title: 'Emission sources + EF library',
          body: 'IPCC / ECOINVENT factors built-in; private EF library supported.',
        },
        {
          src: `${shotDir}/reports.png`,
          title: 'Inventory & disclosure reports',
          body: 'One-click ISO 14064-1 inventory and TCFD four-pillar disclosure export, with full calculations, citations, and version stamp.',
        },
      ],
    };
---
<section class="py-20 px-5">
  <div class="max-w-6xl mx-auto">
    <p class="text-xs font-medium text-primary uppercase tracking-widest mb-3">{tx.label}</p>
    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-2">{tx.title}</h2>
    <p class="text-sm text-muted-foreground mb-10">{tx.sub}</p>

    <div class="grid md:grid-cols-2 gap-6">
      {tx.shots.map((shot) => (
        <figure class="border border-border rounded-lg overflow-hidden bg-card shadow-sm">
          <img
            src={shot.src}
            alt={shot.title}
            width="1400"
            height="900"
            loading="lazy"
            decoding="async"
            class="block w-full h-auto aspect-[1400/900] border-b border-border"
          />
          <figcaption class="p-5">
            <p class="font-semibold text-sm text-foreground mb-1">{shot.title}</p>
            <p class="text-xs text-muted-foreground leading-relaxed">{shot.body}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
