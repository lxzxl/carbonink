---
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import '../styles/global.css';

const { title, lang = 'zh-CN', description } = Astro.props as {
  title: string;
  lang?: 'zh-CN' | 'en';
  description?: string;
};

const defaultDesc = lang === 'zh-CN'
  ? '碳墨（CarbonInk）是免费开源的桌面碳核算 / 碳盘查软件，完全离线运行、数据不出内网。AI 解析票据单据，一键导出 ISO 14064-1 温室气体盘查报告。'
  : 'Free, open-source carbon accounting software for macOS & Windows. Fully offline: AI extracts data from your bills, one click exports an ISO 14064-1 GHG report.';

// Canonical URL + OG image URL — we use carbonink.xyz as the
// public origin. The OG image reuses the hero's dashboard screenshot
// (1400×900 fits the 1.91:1 OG/Twitter card ratio cleanly when
// displayed in Slack / WeChat / Twitter previews). Locale-aware so
// sharing an /en/ link previews the English-UI dashboard, not the
// Chinese one. `noindex` would be wrong here — marketing IS the
// indexable surface.
const canonicalUrl = new URL(Astro.url.pathname, 'https://carbonink.xyz').toString();
const ogImage =
  lang === 'zh-CN'
    ? 'https://carbonink.xyz/screenshots/dashboard.png'
    : 'https://carbonink.xyz/screenshots/en/dashboard.png';

// Compute the mirror-page URL for hreflang. This tells Google that
// `/download` (en, at the apex) and `/zh/download` (zh) are
// translations of the same content, not duplicate pages. Without these tags Google often
// indexes only one locale, hides the other behind a "we filtered
// similar results" notice, or picks the wrong canonical entirely.
//
// `x-default` points to the English version because the site's
// auto-detect logic defaults to English for any non-Chinese browser
// (see the bot-aware redirect script below). Signals to Google
// Search Console: when in doubt, surface the English page to
// international searchers.
const currentPath = Astro.url.pathname;
const isZhPath = currentPath === '/zh' || currentPath.startsWith('/zh/');
// en is the default (apex) locale; zh lives under /zh/. Strip the
// prefix to get the en URL, add it to get the zh URL.
const enPath = isZhPath
  ? currentPath === '/zh' || currentPath === '/zh/'
    ? '/'
    : currentPath.slice(3)
  : currentPath;
const zhPath = isZhPath ? currentPath : currentPath === '/' ? '/zh/' : `/zh${currentPath}`;
const zhUrl = new URL(zhPath, 'https://carbonink.xyz').toString();
const enUrl = new URL(enPath, 'https://carbonink.xyz').toString();

// JSON-LD SoftwareApplication schema. Helps Google understand this
// is a downloadable app (not a SaaS, not a blog), and unlocks rich
// results in the "Software" knowledge panel. CarbonInk is free &
// open-source, so the Offer lists price 0.
// `applicationCategory` follows schema.org's accepted enum values.
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'CarbonInk',
  alternateName: '碳墨',
  description: defaultDesc,
  url: 'https://carbonink.xyz',
  image: ogImage,
  applicationCategory: 'BusinessApplication',
  applicationSubCategory: 'GHG accounting',
  operatingSystem: 'macOS, Windows',
  inLanguage: ['zh-CN', 'en'],
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
  },
  publisher: {
    '@type': 'Organization',
    name: 'CarbonInk',
    url: 'https://carbonink.xyz',
    logo: 'https://carbonink.xyz/favicon.svg',
  },
};

// Standalone Organization schema — separate from the embedded
// `publisher` inside SoftwareApplication. Google reads them
// differently: the embedded one only links the app back to its
// publisher; this top-level Organization entity is what builds the
// Knowledge Panel (logo, contact, social links). Empty `sameAs`
// for now; once social profiles exist (GitHub, X, LinkedIn, 知乎),
// add them here and Google will start showing them in the panel.
const organizationData = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'CarbonInk',
  alternateName: '碳墨',
  url: 'https://carbonink.xyz',
  logo: {
    '@type': 'ImageObject',
    url: 'https://carbonink.xyz/favicon.svg',
    width: '1024',
    height: '1024',
  },
  description: defaultDesc,
};

// WebSite schema — unlocks Google's site-name display ("CarbonInk"
// rather than "carbonink.xyz" in search results) and is the
// container Google looks at when deciding whether to show a
// site-search box under the main listing. `potentialAction` is the
// hook for that search box; we don't have on-site search yet but
// declaring the URL pattern primes the slot.
const websiteData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'CarbonInk',
  alternateName: '碳墨',
  url: 'https://carbonink.xyz',
  inLanguage: ['zh-CN', 'en'],
};

// Baidu / Sogou still parse `<meta name="keywords">`; Google ignores
// it. Cheap to include for the China-side audience. Don't keyword-
// stuff — these are the *actual* search queries we want to rank for.
const keywords =
  lang === 'zh-CN'
    ? '碳核算软件,碳盘查软件,碳盘查,温室气体清单,ISO 14064-1,碳排放核算,排放因子,碳足迹,免费碳核算'
    : 'carbon accounting software,free carbon accounting software,open source carbon accounting,GHG accounting,ISO 14064-1,ghg inventory,scope 1 2 3,carbon footprint software';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Locale detection + auto-redirect.

        Runs synchronously (parser-blocking) BEFORE the title/body, so
        misrouted visitors bounce to the correct mirror page before any
        wrong-language paint. Two responsibilities:

        1. On marketing-surface paths (`/`, `/download`,
           `/privacy` + `/zh/*` mirrors), read the `carbonink_locale`
           cookie. If unset, detect from `navigator.languages` — any
           `zh*` prefix wins → zh-CN, otherwise default to English. Write
           the choice to the cookie (1y). Redirect to the mirror URL if
           the current path doesn't match the preferred locale.

        2. On every page, intercept clicks on any element tagged
           `data-locale-target=zh-CN|en` (the language-toggle button in
           Nav.astro) and write the cookie BEFORE the browser navigates.
           Persists the user's explicit choice across visits and stops
           the detector from bouncing them back to the auto-detected
           locale on the next page load.

        The app is fully local now — there are no auth / account /
        activate surfaces left, so every served path is a marketing
        page and the `isMarketing` gate below covers the whole site. */}
    <script is:inline>
      (function () {
        // Skip the auto-redirect entirely for known search/preview
        // bots. Googlebot DOES execute JavaScript when indexing, so
        // without this short-circuit it would hit `/`, get bounced
        // to `/en/` by the navigator.languages='en' heuristic, and
        // never index the Chinese homepage. The hreflang tags
        // below tell Google about the mirror relationship; this
        // ensures it can actually crawl both sides.
        //
        // Pattern matches the major search bots + social-preview
        // crawlers (Slack/Twitter/Facebook/LinkedIn/WeChat etc.) —
        // anything with "bot", "spider", "crawl" in the UA. Real
        // users essentially never have those tokens.
        var ua = navigator.userAgent || '';
        if (/bot|crawl|spider|slurp|facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|wechat|baiduspider|yandex|duckduck|mediapartners|adsbot/i.test(ua)) {
          return;
        }

        var path = location.pathname;

        var isMarketing = /^\/(zh\/?)?(download|privacy)?\/?$/.test(path);
        if (isMarketing) {
          var isZh = path === '/zh' || path.indexOf('/zh/') === 0;
          var m = document.cookie.match(/(?:^|;\s*)carbonink_locale=(zh-CN|en)/);
          var preferred = m ? m[1] : null;
          if (!preferred) {
            var langs = (navigator.languages && navigator.languages.length)
              ? navigator.languages
              : [navigator.language || ''];
            preferred = 'en';
            for (var i = 0; i < langs.length; i++) {
              var l = (langs[i] || '').toLowerCase();
              if (l.indexOf('zh') === 0) { preferred = 'zh-CN'; break; }
              if (l.indexOf('en') === 0) { preferred = 'en'; break; }
            }
            document.cookie = 'carbonink_locale=' + preferred + '; path=/; max-age=31536000; SameSite=Lax';
          }
          if (preferred === 'zh-CN' && !isZh) {
            location.replace('/zh' + path + location.search + location.hash);
            return;
          }
          if (preferred === 'en' && isZh) {
            var stripped = (path === '/zh' || path === '/zh/') ? '/' : path.slice(3);
            location.replace(stripped + location.search + location.hash);
            return;
          }
        }

        document.addEventListener('click', function (ev) {
          var t = ev.target;
          while (t && t !== document.body && !(t.getAttribute && t.getAttribute('data-locale-target'))) {
            t = t.parentNode;
          }
          if (t && t !== document.body) {
            var target = t.getAttribute('data-locale-target');
            if (target === 'zh-CN' || target === 'en') {
              document.cookie = 'carbonink_locale=' + target + '; path=/; max-age=31536000; SameSite=Lax';
            }
          }
        });
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description ?? defaultDesc} />
    <link rel="canonical" href={canonicalUrl} />

    {/* hreflang alternates — declare the zh-CN ↔ en mirror
        relationship so Google merges link-equity across both
        locales instead of treating them as duplicates. `x-default`
        falls back to English for international searchers (matches
        the auto-detect default in the script above). Both `href`
        values are absolute URLs (Google ignores relative ones). */}
    <link rel="alternate" hreflang="zh-CN" href={zhUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    {/* Three JSON-LD blocks — schema.org recommends emitting
        multiple smaller @type entities rather than nesting them in
        a single @graph. Google parses each independently:
        - SoftwareApplication: app metadata, OS, free Offer (price 0)
        - Organization: builds the Knowledge Panel (logo, sameAs)
        - WebSite: site-name display + search-action hook */}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationData)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(websiteData)} />

    {/* Baidu-targeted keywords meta — Google has ignored this since
        2009 but Baidu/Sogou still factor it in. Lives outside the
        SEO main path; safe to drop later if the China audience
        proves not to matter. */}
    <meta name="keywords" content={keywords} />

    {/* theme-color drives the browser-chrome color on mobile
        (Android Chrome address bar; iOS Safari status bar in PWA
        context). Moss-green matches the LogoMark accent so the
        chrome reads as part of the same identity. */}
    <meta name="theme-color" content="#6B8266" />

    {/* Favicon — inline SVG re-uses the LogoMark vector, so the tab
        icon, bookmark icon, and in-page brand all read as the same
        identity. PNG fallback not shipped today; modern browsers
        (Chrome 80+, Safari 12+, Firefox 41+) all honor SVG favicons,
        and the cloud site doesn't need to support IE. */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Open Graph + Twitter Card metadata.
        Slack / WeChat / Twitter / LinkedIn / Telegram all read OG
        first; the screenshot embed makes the link preview show the
        real dashboard, not a generic logo card. og:type=website
        because the marketing pages are not articles. */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="CarbonInk" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description ?? defaultDesc} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1400" />
    <meta property="og:image:height" content="900" />
    <meta property="og:image:alt" content={lang === 'zh-CN' ? '碳墨桌面端 — 仪表盘截图' : 'CarbonInk desktop — dashboard screenshot'} />
    <meta property="og:locale" content={lang === 'zh-CN' ? 'zh_CN' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'zh-CN' ? 'en_US' : 'zh_CN'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description ?? defaultDesc} />
    <meta name="twitter:image" content={ogImage} />

    {/* Fonts are self-hosted from /fonts/ (see global.css @font-face).
        The Google Fonts CDN is blocked in mainland China, which stalled
        zh visitors on the preconnect; same-origin woff2 rides our own
        Cloudflare edge everywhere. Preload the Latin variable font (the
        only render-critical file — CJK uses the system stack, no
        download). `crossorigin` is required even same-origin: font
        fetches are CORS-mode, and a mismatch double-downloads. */}
    <link
      rel="preload"
      href="/fonts/InterVariable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body class="bg-background text-foreground font-[family-name:var(--font-body)] min-h-screen flex flex-col">
    <Nav lang={lang} />
    {/* pt-14 clears the fixed Nav (h-14). `flex-1` keeps the footer at
        the bottom of short pages without the awkward "footer floating
        in the middle" effect on near-empty placeholder pages. */}
    <main class="flex-1 pt-14"><slot /></main>
    <Footer lang={lang} />
  </body>
</html>
