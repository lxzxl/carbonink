# Dependencies
node_modules/
.pnpm-store/
.pnp.*

# Build artifacts
dist/
out/
release/
# NOTE: `build/` is NOT ignored. It holds committed electron-builder
# resources (app icons, macOS entitlements, Windows sign hook). See
# `build/README.md`.

# Electron
*.app
*.dmg
*.exe
*.AppImage
*.deb
*.rpm

# Local data (user-generated, not for repo)
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
data/
local/
.cache/
# Bundled preset catalog files live under desktop/src/main/data/ — committed.
!desktop/src/main/data/
!desktop/src/main/data/**

# Env / secrets
.env
.env.local
.env.*.local
auth.json

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test
coverage/
.vitest-cache/

# Misc
*.tsbuildinfo
.turbo/

# Playwright artifacts
test-results/
playwright-report/

# Ad-hoc UI screenshots dropped by the user for design review.
# Not part of the source tree; kept locally for reference.
#
# Exception: cloud/web/public/screenshots/ ARE production assets —
# they're embedded in the marketing hero + gallery and must ship.
# The `!` re-include below overrides the `screenshots/` rule for
# that one path only.
screenshots/
!cloud/web/public/screenshots/
!cloud/web/public/screenshots/**

# Figma Make reference bundle — used as a design source while
# rebuilding cloud/web, never deployed. Keep locally for reference
# but don't commit.
Landing Marketing Pages/

# Climatiq API page dumps cached by desktop/scripts/climatiq-to-presets.mjs.
# Regenerable from the public API; the OUTPUT (preset-sources.json) IS committed.
desktop/scripts/.climatiq-cache/

# Preview tool dev-server config (per-user, points to absolute paths).
.claude/launch.json

# Inbound supplier-disclosure xlsx exported during manual smoke testing.
# The app writes `inbound-<uuid>.xlsx` via the export save-dialog; these
# are throwaway test artifacts, never source.
desktop/inbound-*.xlsx

# Per-feature design docs — kept locally, NOT tracked. They're the dev-process
# trail (brainstorm → spec → plan, plus research / release-notes / archive),
# not shipped artifacts. The living references (docs/conventions/,
# docs/ROADMAP.md, docs/README.md) stay tracked. See docs/README.md.
docs/specs/
docs/plans/
docs/research/
docs/release-notes/
docs/todo/
docs/archive/

# Eval harness output (timestamped runs) — regenerable, not source.
desktop/scripts/eval/results/
