{
  "name": "carbonbook-monorepo",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20", "pnpm": ">=10" },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "desktop:dev": "pnpm --filter carbonbook dev",
    "desktop:build": "pnpm --filter carbonbook build",
    "desktop:test": "pnpm --filter carbonbook test",
    "desktop:typecheck": "pnpm --filter carbonbook typecheck",
    "desktop:lint": "pnpm --filter carbonbook lint",
    "cloud:test": "pnpm --filter @carbonbook-cloud/worker test",
    "cloud:lint": "pnpm exec biome check cloud",
    "cloud:build:marketing": "pnpm --filter @carbonbook-cloud/marketing build",
    "cloud:build:activate": "pnpm --filter @carbonbook-cloud/activate build",
    "cloud:build:account": "pnpm --filter @carbonbook-cloud/account build",
    "test": "pnpm -r --workspace-concurrency=1 run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "sharp",
      "workerd",
      "@napi-rs/canvas-darwin-arm64",
      "@napi-rs/canvas-darwin-x64",
      "@napi-rs/canvas-linux-x64-gnu",
      "@napi-rs/canvas-win32-x64-msvc"
    ]
  }
}
